POSTGRES_USER=disaster_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=disaster_alert
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=sk-your-openai-api-key
# For OpenAI: leave empty (defaults to https://api.openai.com/v1)
# For NVIDIA NIM: https://integrate.api.nvidia.com/v1
OPENAI_BASE_URL=
# Text model: gpt-4o-mini (OpenAI) or meta/llama-3.3-70b-instruct (NVIDIA, free)
TEXT_MODEL=gpt-4o-mini
# Image model: dall-e-3 (OpenAI only, leave empty to skip image generation)
IMAGE_MODEL=dall-e-3

FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
META_GRAPH_API_VERSION=v18.0

NEWS_API_KEY=your-news-api-key
# NewsData.io — free tier (200 req/day), alternative Philippine news source
NEWSDATA_API_KEY=your-newsdata-api-key
# NewsData.io categories: crime,disaster,top,environment,politics,world,etc.
NEWSDATA_CATEGORIES=crime,disaster,top,environment
# OpenWeatherMap — free tier (1000 calls/day), used for weather alerts
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
# Coordinates for Mountain Province (defaults to Bontoc area)
WEATHER_LAT=17.09
WEATHER_LON=121.03
# USGS earthquake API — free, no key needed
EARTHQUAKE_API_URL=https://earthquake.usgs.gov/fdsnws/event/1/query

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

SECRET_KEY=changeme-secret-key-for-jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_pass

POLLING_INTERVAL_MINUTES=60
MAX_POSTS_PER_HOUR=5

DISASTER_KEYWORDS=earthquake,flood,typhoon,landslide,volcano,tsunami,storm,tremor,evacuation,bagyo,lindol,baha,rain,heavy rain,downpour,car accident,road accident,vehicular accident,road crash,collision,fire,wildfire,sunog,rescue,missing person,power outage,blackout,brownout,water shortage,Mountain Province,Bontoc,Sagada,Bauko,Besao,Sabangan,Tadian,Natonin,Paracelis,Barlig,Sadanga